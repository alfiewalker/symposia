# Symposia environment template
# Copy to .env (repo root) and fill only what you need.

# Provider API keys (set at least one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional: explicit config file path
# If unset, Symposia searches default locations (see symposia/config/loader.py)
SYMPOSIA_CONFIG=examples/symposia.local.yaml
